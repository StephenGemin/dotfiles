{{ if eq .osid "darwin" -}}
#!/bin/bash

# https://www.chezmoi.io/user-guide/use-scripts-to-perform-actions/#run-a-script-when-the-contents-of-another-file-changes
# Re-run this script whenever the Homebrew package list changes. The brews and
# casks below are rendered from .chezmoidata/brew.yaml, so embedding that file's
# hash here triggers a re-run when it is edited.
{{ $brew_data := joinPath .chezmoi.sourceDir ".chezmoidata" "brew.yaml" -}}
# {{ include $brew_data | sha256sum }}

set -eu  # -e: exit on error; -u exit on unset variables
set +x   # disable debug mode

pipxs=(
{{- range (concat .pipx.common .pipx.darwin) }}
    {{ . | quote }}
{{- end }}
)


command_exists() {
    if type "$1" >/dev/null 2>&1; then
        echo "$1 already installed"
        return 0
    fi
    return 1
}

install_pipxs() {
    pipx ensurepath
    for pkg in "${pipxs[@]}"; do
        echo "Install pipx package: $pkg"
        pipx install --python=$(which python) "$pkg"
    done
}


show_hidden_files_in_finder() {
    # Show hidden files in Finder application
    defaults write com.apple.Finder AppleShowAllFiles true
    killall Finder
}

# Install git diff-highlight
install_git_diff_highlight() {
    # Target git's `opt` prefix, not the version-pinned Cellar path: opt/git
    # always follows the current git, so the link survives `brew upgrade git`
    # instead of dangling. No command_exists guard — `type` treats a dangling
    # link as present and would skip the repair; `ln -sf` is idempotent and
    # re-points a stale link on every run.
    local diff_highlight_path
    diff_highlight_path="$(brew --prefix git)/share/git-core/contrib/diff-highlight/diff-highlight"
    if [[ -f "$diff_highlight_path" ]]; then
        ln -sf "$diff_highlight_path" ~/.local/bin/diff-highlight
        echo "Installed diff-highlight"
    else
        echo "Could not find diff-highlight, verify Git's contrib scripts are installed."
    fi
}

install_python(){
    if command_exists pyenv; then
        if ! command_exists python; then
            pyenv install {{ .user.software.python_version }}
            pyenv global {{ .user.software.python_version }}
        fi
    fi
}
install_xcode_select(){
    if ! command_exists xcode-select; then
      xcode-select --install
    fi
}

install_rustup() {
    if command_exists rustup; then
        return
    fi
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
}

# Homebrew requires trusting Microsoft's own tap
install_powershell() {
    if command_exists pwsh; then
        return
    fi
    brew trust powershell/tap
    brew install powershell/tap/powershell
}

# run program
install_xcode_select

if [ "${CI:-}" = "true" ]; then
    echo "[CI] Would brew bundle: {{ len .packages.darwin.brews }} brews, {{ len .packages.darwin.casks }} casks"
    echo "[CI] Would install pipx packages: ${pipxs[*]}"
    echo "[CI] Would install diff-highlight, python {{ .user.software.python_version }}, rustup"
    echo "[CI] Would trust powershell/tap and install PowerShell"
    echo "[CI] Would show hidden files in Finder"
else
    brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF

    show_hidden_files_in_finder
    install_pipxs
    install_git_diff_highlight
    install_python
    install_rustup
    install_powershell
fi

echo "All installations completed successfully!"
{{ end -}}

