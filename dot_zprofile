# ran into issue with brew mismatch for arm64 Mac; was using x86_64 (aka intel) brew
if [ "$(uname)" = "Darwin" ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"

  # /etc/zprofile runs path_helper before this file, rebuilding PATH with the
  # system paths first — which demotes whatever .zshenv prepended below
  # /usr/bin. Re-prepend the user bins here so they win again.
  [ -d "$HOME/bin" ] && export PATH="$HOME/bin:$PATH"
  [ -d "$HOME/.local/bin" ] && export PATH="$HOME/.local/bin:$PATH"
fi

if [ -f "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
