# -*-mode:gitconfig-*- vim:ft=gitconfig

# ~/.gitconfig
# =============================================================================
# User-specific Git configuration file.
#
# See https://git-scm.com/docs/git-config
#
# {{- /* This file supports Go's text/template language. */ -}}
#
# Sources:
#     https://delicious-insights.com/en/posts/mastering-git-submodules/
#     https://github.com/haacked/dotfiles
#     https://github.com/holman/dotfiles
#     https://github.com/jayharris/dotfiles-windows
#     https://github.com/mathiasbynens/dotfiles
#     https://git-scm.com/docs/git-config/

[user]
    name = "{{- .name }}"
    email = "{{- .email }}"
[branch]
    sort = -committerdate
{{ if ne .osid "windows" -}}
[color]
    ui = true
# colors taken from https://github.com/so-fancy/diff-so-fancy
[color "diff-highlight"]
    oldNormal = red bold
    oldHighlight = yellow bold 52
    newNormal = green bold
    newHighlight = cyan bold 22
[color "diff"]
    meta = 11
    frag = magenta bold
    func = 146 bold
    commit = yellow bold
    old = red bold
    new = green bold
    whitespace = red reverse
{{- end }}
[column]
    ui = auto
[commit]
    template = ~/.config/git/commit_message_template
    # Show the diff being committed in the commit message editor. This makes the
    # explicit `--verbose` flag in the shell/pwsh commit aliases unnecessary.
    verbose = true
[core]
    autocrlf = {{ if eq .osid "windows" }}true{{ else }}input{{ end }}
    editor = nvim
    excludesfile = ~/.config/git/ignore_global

    # Speed up commands involving untracked files such as `git status`.
    # See https://git-scm.com/docs/git-update-index#_untracked_cache
    untrackedCache = true

    # Set comment character to something that allows mentioning issue numbers.
    commentChar = ";"
[diff]
    # The histogram algorithm produces more readable diffs than the default.
    algorithm = histogram
[fetch]
    # Remove any remote-tracking references that no longer exist on the remote.
    prune = true
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[help]
    # Suggest the corrected command and prompt before running it.
    autocorrect = prompt
[include]
    path = ~/.config/git/config_local  # include local configuration (optional)
[init]
    defaultBranch = main
[interactive]
    diffFilter = diff-highlight
[merge]
    # Include summaries of merged commits in newly created merge commit messages.
    log = true
    # Show the common ancestor alongside both sides in conflict markers.
    conflictStyle = zdiff3
[mergetool]
    # Avoid saving an `.orig` backup file after a merge.
    keepBackup = false
{{ if ne .osid "windows" -}}
[pager]
    log = diff-highlight | less
    show = diff-highlight | less
    diff = diff-highlight | less
{{- end }}
[push]
    autoSetupRemote = true
    default = current
[rebase]
    autosquash = true
    # Stash dirty changes before rebasing and reapply them afterwards.
    autoStash = true
[rerere]
    enabled = true
    # Stage the replayed conflict resolution automatically.
    autoUpdate = true
[tag]
    sort = version:refname
