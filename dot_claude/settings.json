{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Bash(git push *)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/no-session-link.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "effortLevel": "high",
  "advisorModel": "opus",
  "askUserQuestionTimeout": "never",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "dark",
  "editorMode": "normal",
  "switchModelsOnFlag": true,
  "remoteControlAtStartup": true,
  "voiceEnabled": true
}
